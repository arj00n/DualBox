<Window x:Class="DualBox.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DualBox" Height="660" Width="900" MinHeight="620" MinWidth="820">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Text="DualBox" FontSize="30" FontWeight="SemiBold" />
      <TextBlock Text="PS5 DualSense to Xbox One-style controller bridge" Foreground="#AAB2C0" Margin="0,6,0,18" />
    </StackPanel>

    <Border Grid.Row="1" Background="#181C24" BorderBrush="#2A3140" BorderThickness="1" CornerRadius="8" Padding="18">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
          <TextBlock x:Name="StatusText" Text="Idle" FontSize="18" FontWeight="SemiBold" />
          <TextBlock x:Name="DeviceText" Text="No controller connected" Foreground="#AAB2C0" Margin="0,6,0,0" />
          <TextBlock x:Name="PrereqText" Text="Checking drivers..." Foreground="#AAB2C0" Margin="0,6,0,0" />
        </StackPanel>

        <StackPanel Grid.Column="1">
          <TextBlock Text="Touchpad press" Foreground="#AAB2C0" Margin="0,0,0,6" />
          <ComboBox x:Name="TouchpadMappingCombo" SelectedIndex="0" Margin="0,0,0,14" SelectionChanged="SettingsCombo_OnSelectionChanged">
            <ComboBoxItem Content="View / Back" Tag="Back" />
            <ComboBoxItem Content="Menu / Start" Tag="Start" />
            <ComboBoxItem Content="Guide" Tag="Guide" />
            <ComboBoxItem Content="Disabled" Tag="None" />
          </ComboBox>

          <TextBlock Text="Adaptive triggers" Foreground="#AAB2C0" Margin="0,0,0,6" />
          <ComboBox x:Name="TriggerProfileCombo" SelectedIndex="0" Margin="0,0,0,14" SelectionChanged="SettingsCombo_OnSelectionChanged">
            <ComboBoxItem Content="Racing" Tag="Racing" />
            <ComboBoxItem Content="Off" Tag="Off" />
          </ComboBox>

          <CheckBox x:Name="StartWithWindowsCheck" Content="Open on Windows launch" Margin="0,0,0,8" Checked="SettingsInput_OnChanged" Unchecked="SettingsInput_OnChanged" />
          <CheckBox x:Name="PsGameBarCheck" Content="PS button opens Game Bar" Margin="0,0,0,14" Checked="SettingsInput_OnChanged" Unchecked="SettingsInput_OnChanged" />

          <StackPanel Orientation="Horizontal">
            <Button x:Name="StartButton" Content="Start bridge" Click="StartButton_OnClick" />
            <Button x:Name="StopButton" Content="Stop" Click="StopButton_OnClick" IsEnabled="False" />
            <Button x:Name="RumbleButton" Content="Test feedback" Click="RumbleButton_OnClick" IsEnabled="False" />
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="2" Margin="0,18,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Background="#181C24" BorderBrush="#2A3140" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,12,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <TextBlock Text="Event log" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
          <ListBox x:Name="LogList" Grid.Row="1" Background="#10141B" Foreground="#D9DEE8" BorderBrush="#2A3140" />
        </Grid>
      </Border>

      <Border Grid.Column="1" Background="#181C24" BorderBrush="#2A3140" BorderThickness="1" CornerRadius="8" Padding="16">
        <StackPanel>
          <TextBlock Text="Live input" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
          <TextBlock x:Name="LeftStickText" Text="Left stick: -" Foreground="#D9DEE8" Margin="0,0,0,8" />
          <TextBlock x:Name="RightStickText" Text="Right stick: -" Foreground="#D9DEE8" Margin="0,0,0,8" />
          <TextBlock x:Name="FilteredStickText" Text="Filtered Xbox sticks: -" Foreground="#D9DEE8" TextWrapping="Wrap" Margin="0,0,0,8" />
          <TextBlock x:Name="TriggerText" Text="Triggers: -" Foreground="#D9DEE8" Margin="0,0,0,8" />
          <ProgressBar x:Name="LeftTriggerBar" Minimum="0" Maximum="255" Height="8" Margin="0,0,0,8" />
          <ProgressBar x:Name="RightTriggerBar" Minimum="0" Maximum="255" Height="8" Margin="0,0,0,12" />
          <TextBlock x:Name="ButtonText" Text="Buttons: -" Foreground="#D9DEE8" TextWrapping="Wrap" Margin="0,0,0,18" />
          <TextBlock x:Name="RumbleText" Text="Last feedback: -" Foreground="#D9DEE8" TextWrapping="Wrap" Margin="0,0,0,18" />
          <TextBlock Text="Stick drift fix" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
          <TextBlock x:Name="LeftDeadzoneText" Text="Left deadzone: 7%" Foreground="#AAB2C0" Margin="0,0,0,4" />
          <Slider x:Name="LeftDeadzoneSlider" Minimum="0" Maximum="0.25" Value="0.07" TickFrequency="0.01" IsSnapToTickEnabled="True" ValueChanged="SettingsSlider_OnChanged" Margin="0,0,0,10" />
          <TextBlock x:Name="RightDeadzoneText" Text="Right deadzone: 7%" Foreground="#AAB2C0" Margin="0,0,0,4" />
          <Slider x:Name="RightDeadzoneSlider" Minimum="0" Maximum="0.25" Value="0.07" TickFrequency="0.01" IsSnapToTickEnabled="True" ValueChanged="SettingsSlider_OnChanged" Margin="0,0,0,18" />
          <TextBlock x:Name="DriftStatusText" Text="Drift status: -" Foreground="#AAB2C0" TextWrapping="Wrap" Margin="0,0,0,18" />
          <TextBlock Text="Notes" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
          <TextBlock Text="Use USB for best rumble fidelity. Bluetooth rumble is supported by report format, but USB is the first test target." Foreground="#AAB2C0" TextWrapping="Wrap" />
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</Window>
